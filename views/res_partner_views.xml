<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_partner_form_modificado" model="ir.ui.view">
            <field name="name">res.partner.form.modificado</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
              <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="placeholder">Departamento</attribute>
              </xpath>
              <xpath expr="//field[@name='city']" position="attributes">
                <attribute name="placeholder">Municipio</attribute>
              </xpath>
              <field name="vat" position="after">
                  <field name="giro_negocio_id"/>
              </field>

              <field name="category_id" position="after">
                  <field name="vendedor"/>
              </field>

            </field>
        </record>

        <record id="view_partner_form_userid_editable_group" model="ir.ui.view">
            <field name="name">res.partner.form.user_id.editable.group</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <field name="user_id" position="attributes" groups="imporgesa.group_partner_userid_editable">
                    <attribute name="readonly">0</attribute>
                </field>
            </field>
        </record>

    </data>
</odoo>
